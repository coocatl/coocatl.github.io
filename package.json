{
  "name": "li-jiaying-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-static-routes.mjs",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --pretty false",
    "validate": "node scripts/validate-content.mjs",
    "validate-content": "node scripts/validate-content.mjs",
    "qa": "npm run lint && npm run typecheck && npm run validate-content && npm run build",
    "qa:baseline": "node scripts/capture-baseline.mjs",
    "qa:references": "node scripts/capture-references.mjs",
    "qa:reference-interactions": "node scripts/capture-reference-interactions.mjs",
    "qa:visual-directions": "node scripts/capture-visual-directions.mjs",
    "media:optimize": "node scripts/optimize-media.mjs",
    "qa:production": "node scripts/qa-production.mjs",
    "qa:round2": "node scripts/qa-round-2.mjs",
    "qa:pages": "node scripts/qa-pages.mjs",
    "qa:performance": "node scripts/measure-performance.mjs"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "gsap": "^3.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "playwright-core": "^1.61.1",
    "sharp": "^0.35.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.1.4"
  }
}
